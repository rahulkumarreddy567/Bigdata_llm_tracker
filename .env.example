# LLM Tracker Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================
# AIRFLOW CONFIGURATION
# ============================================

# Airflow Executor
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Database Connection
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow

# Fernet Key for data encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
AIRFLOW__CORE__FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# DAG Configuration
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=false
AIRFLOW__CORE__LOAD_EXAMPLES=false

# Webserver Configuration
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=true

# API Authentication
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session

# ============================================
# POSTGRESQL CONFIGURATION
# ============================================

# Database Credentials (⚠️ Change in production!)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ============================================
# ELASTICSEARCH CONFIGURATION
# ============================================

# Java Memory Options
ES_JAVA_OPTS=-Xms512m -Xmx512m

# Security (disabled for development - enable in production)
XPACK_SECURITY_ENABLED=false

# ML Features
xpack.ml.enabled=false

# ============================================
# KIBANA CONFIGURATION
# ============================================

# Elasticsearch Hosts
ELASTICSEARCH_HOSTS=http://elasticsearch:9200

# Security
XPACK_SECURITY_ENABLED=false

# ============================================
# DATA SOURCE CONFIGURATION
# ============================================

# OpenRouter API Configuration (if using external API)
# OPENROUTER_API_KEY=your_api_key_here
# OPENROUTER_BASE_URL=https://api.openrouter.co/api/v1

# LMSYS Configuration
# LMSYS_BASE_URL=https://huggingface.co/spaces/lmsys/chatbot-arena-leaderboard

# ============================================
# PRODUCTION OVERRIDES
# ============================================

# Uncomment and modify these settings for production deployment:

# AIRFLOW__CORE__EXECUTOR=CeleryExecutor
# AIRFLOW__CORE__LOAD_EXAMPLES=false
# AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false
# AIRFLOW__WEBSERVER__AUTHENTICATE=true
# AIRFLOW__WEBSERVER__AUTH_BACKEND=airflow.contrib.auth.backends.ldap_auth
# AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
# POSTGRES_PASSWORD=change_me_to_strong_password
# ES_JAVA_OPTS=-Xms2g -Xmx2g

# ============================================
# NOTES
# ============================================
# - ⚠️ NEVER commit actual secrets to version control
# - Use AWS Secrets Manager, HashiCorp Vault, or similar for production
# - Change all default passwords before production deployment
# - Uncomment production settings and update values appropriately
# - For Fernet key generation: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
