# ============================================================
# LLM Tracker - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your secure values
# NEVER commit .env to version control!
# ============================================================

# PostgreSQL (Airflow metadata database)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change_this_to_a_secure_password_123
POSTGRES_DB=airflow

# Airflow Web UI Admin User
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_this_to_a_secure_password_456

# Airflow Fernet Key (encrypts passwords and connections)
# Generate new: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# Airflow Database Connection
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:change_this_to_a_secure_password_123@postgres/airflow

# Elasticsearch Configuration
ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=change_this_to_a_secure_password_789

# API Credentials (if needed for external services)
OPENROUTER_API_KEY=your_openrouter_key_if_needed
LMSYS_API_KEY=your_lmsys_key_if_needed

# Email Configuration (optional - for Airflow alerts)
AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_USER=your_email@gmail.com
AIRFLOW__SMTP__SMTP_PASSWORD=your_app_password
AIRFLOW__SMTP__SMTP_MAIL_FROM=airflow@yourdomain.com

# Logging
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO
AIRFLOW__CORE__LOG_LEVEL=INFO

# Security
AIRFLOW__CORE__EXPOSE_CONFIG=false
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false
