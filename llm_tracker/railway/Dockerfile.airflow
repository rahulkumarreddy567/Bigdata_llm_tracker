FROM apache/airflow:2.8.1-python3.11

COPY requirements-airflow.txt /requirements-airflow.txt
RUN pip install --no-cache-dir -r /requirements-airflow.txt

COPY dags /opt/airflow/dags
COPY ingestion /opt/airflow/ingestion
COPY dbt_project /opt/airflow/dbt_project
COPY indexing /opt/airflow/indexing
COPY kibana /opt/airflow/kibana
COPY setup_kibana_dashboard.py /opt/airflow/setup_kibana_dashboard.py
COPY railway/airflow-common.sh /opt/airflow/airflow-common.sh
COPY railway/airflow-webserver-start.sh /opt/airflow/airflow-webserver-start.sh
COPY railway/airflow-scheduler-start.sh /opt/airflow/airflow-scheduler-start.sh
COPY railway/create-kibana-dashboard.sh /opt/airflow/create-kibana-dashboard.sh

RUN chmod +x /opt/airflow/airflow-common.sh \
    /opt/airflow/airflow-webserver-start.sh \
    /opt/airflow/airflow-scheduler-start.sh \
    /opt/airflow/create-kibana-dashboard.sh \
 && mkdir -p /opt/airflow/data

CMD ["/opt/airflow/airflow-webserver-start.sh"]
